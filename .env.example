# Runtime mode. Use development locally so SECRET_KEY can be generated if omitted.
ENVIRONMENT=development

# Backend
PROJECT_NAME=N.E.K.O Plugin Market
VERSION=1.0.0
DATABASE_URL=sqlite+aiosqlite:///./plugin_market.db
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_HOSTS=["*"]

# GitHub integration. Optional for public repositories, recommended for higher rate limits.
GITHUB_TOKEN=

# AI review integration. Optional unless using AI review endpoints.
AI_API_KEY=
AI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-4
AI_SANDBOX_TIMEOUT=300
AI_MAX_CONCURRENT=3
AI_MAX_CALLS_PER_DAY=1000

# JWT key rotation
JWT_KEY_ROTATION_DAYS=30
JWT_KEY_KEEP_COUNT=3

# Log retention
REVIEW_LOG_RETENTION_DAYS=90
SANDBOX_LOG_RETENTION_DAYS=30
PERMISSION_AUDIT_RETENTION_DAYS=180
LOG_CLEANUP_INTERVAL_HOURS=24

# SMTP. Optional unless email notifications are enabled.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_FROM=

# Frontend. Copy this into NEKO_Plugins_Market/.env.local if needed.
VITE_API_BASE_URL=http://localhost:8000/api/v1
