# Copy to .env.production before running docker-compose.prod.yml.
# Generate secrets locally, for example:
#   openssl rand -hex 32

ENVIRONMENT=production
PROJECT_NAME=N.E.K.O Plugin Market
VERSION=1.0.0

# Caddy site address. Use ":80" for local dry runs, or your real domain for TLS.
# Examples:
#   MARKET_SITE_ADDRESS=:80
#   MARKET_SITE_ADDRESS=market.example.com
MARKET_SITE_ADDRESS=:80
MARKET_HTTP_PORT=80
MARKET_HTTPS_PORT=443

# Backend public URL used in OAuth/email redirects and CORS.
FRONTEND_BASE_URL=http://localhost
ALLOWED_HOSTS=["http://localhost"]

# SQLite production storage. The /data path is backed by the market_data volume.
DATABASE_URL=sqlite+aiosqlite:////data/plugin_market.db
DEV_AUTO_CREATE_TABLES=false

SECRET_KEY=change-me-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Initial admin is created only when no admin exists. Change immediately.
INITIAL_ADMIN_USERNAME=root
INITIAL_ADMIN_EMAIL=root@example.com
INITIAL_ADMIN_PASSWORD=change-me-before-first-start

# Development-only auth must stay disabled in production.
DEBUG_AUTH_ENABLED=false
DEBUG_AUTH_USERNAME=debug_user
DEBUG_AUTH_EMAIL=debug@example.com
DEBUG_AUTH_IS_ADMIN=false

# GitHub integration. Recommended to avoid release API rate limits.
GITHUB_TOKEN=

# Optional AI review integration.
AI_API_KEY=
AI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-4
AI_SANDBOX_TIMEOUT=300
AI_MAX_CONCURRENT=3
AI_MAX_CALLS_PER_DAY=1000

# JWT key rotation.
JWT_KEY_ROTATION_DAYS=30
JWT_KEY_KEEP_COUNT=3

# Log retention.
REVIEW_LOG_RETENTION_DAYS=90
SANDBOX_LOG_RETENTION_DAYS=30
PERMISSION_AUDIT_RETENTION_DAYS=180
LOG_CLEANUP_INTERVAL_HOURS=24

# Optional SMTP.
EMAIL_DELIVERY_MODE=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SSL=false
SMTP_TLS=true
SMTP_FROM=
